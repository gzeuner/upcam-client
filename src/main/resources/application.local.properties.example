# -----------------------------------------------------------------------------
# Local/private runtime config template
# Copy this file to: application.local.properties
# This file is intentionally not tracked by git (.gitignore).
# -----------------------------------------------------------------------------

# Select source
camera.type=REOLINK

# Poll interval
upcam.reload.sec=2

# Storage
image.local.store.rcv=./images/received/
image.local.store.snt=./images/sent/
file.max.age.days=2
lock.file=./.lock/upcamclient.lock

# Cleanup
cleanup.enabled=true
cleanup.interval.seconds=300
cleanup.images.enabled=true
cleanup.images.maxAgeDays=2
cleanup.images.maxAgeHours=12
cleanup.images.maxFilesPerDir=250
cleanup.logs.enabled=true
cleanup.logs.dir=./logs/
cleanup.logs.maxAgeDays=30

# Prefilter
prefilter.enabled=true
prefilter.hashType=roi-motion
prefilter.resizeWidth=384
prefilter.cropTopPx=24
prefilter.hammingThreshold=6
prefilter.maxSuppressSeconds=4
prefilter.cameraSignalBypass=true
prefilter.mode=quarantine
prefilter.noiseDir=./images/noise/
prefilter.stateFile=./.state/upcam_prefilter_state.json
prefilter.minBytes=8000
prefilter.failMode=open
prefilter.noise.maxFiles=80
prefilter.observeOnly=true

# UPCAM credentials (used when camera.type=UPCAM)
base.url=http://upcam.local
image.daily.root.resource=/sd/${day}
image.html.pattern=a[href*=images]
upcam.listingUrl=
upcam.user.name=
upcam.user.pwd=

# REOLINK credentials (used when camera.type=REOLINK)
reolink.host=reolink.local
reolink.httpPort=80
reolink.username=
reolink.password=
reolink.snapshotPath=/cgi-bin/api.cgi?cmd=Snap&channel=0&rs={timestamp}&user={usernameEncoded}&password={passwordEncoded}
reolink.snapshotUrl=
reolink.verifyTls=false
reolink.burst.enabled=true
reolink.burst.count=2
reolink.burst.intervalMs=350
reolink.burst.requireSignal=false
